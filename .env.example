# Root environment file — copy to .env and fill in values
# Sub-project env files are distributed from here

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key

# Google Gemini (for AI suggestion verification)
GEMINI_API_KEY=AIzaSy...

# Admin (comma-separated list of admin email addresses)
ADMIN_EMAILS=admin@example.com

# Use ANON key here (read-only). Never use SERVICE_ROLE_KEY in MCP server.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...anon_key

# Upstash Redis (REST) for cross-instance cache + rate limiting.
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Error tracking (optional locally).
SENTRY_DSN=

# Set automatically by Railway. Leave blank for local (defaults to 8000).
PORT=
